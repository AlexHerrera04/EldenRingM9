<!DOCTYPE html>
<html lang="ca" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Elden Ring — Bosses, Història i Lore de les Terres Entremig" />
    <title>@ViewData["Title"] — Elden Ring Wiki</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <a class="skip-link" href="#main-content">Saltar al contingut principal</a>

    <nav class="navbar navbar-expand-lg" role="navigation" aria-label="Navegació principal">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">✦ Elden Ring</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navbarMain" aria-controls="navbarMain"
                    aria-expanded="false" aria-label="Alternar navegació">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav ms-auto" role="list">
                    <li class="nav-item" role="listitem"><a class="nav-link" asp-controller="Home" asp-action="Index">Inici</a></li>
                    <li class="nav-item" role="listitem"><a class="nav-link" asp-controller="Boss" asp-action="Index">Bosses</a></li>
                    <li class="nav-item" role="listitem"><a class="nav-link" asp-controller="Boss" asp-action="Ranking">Rànquing</a></li>
                    <li class="nav-item" role="listitem"><a class="nav-link" asp-controller="Lore" asp-action="Index">Lore</a></li>
                    <li class="nav-item" role="listitem"><a class="nav-link" asp-controller="Boss" asp-action="ApiData">API Live</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <main id="main-content" role="main">
        @RenderBody()
    </main>

    <footer role="contentinfo">
        <div class="container">
            <p>© @DateTime.Now.Year — Elden Ring Wiki MVC · CFGS DAW · MP09 Projecte Final</p>
            <p style="font-size:0.7rem; margin-top:0.3rem; opacity:0.4;">Elden Ring és marca registrada de FromSoftware, Inc. Lloc creat amb finalitats educatives.</p>
        </div>
    </footer>

    <!-- Hidden YouTube Player -->
    <div id="yt-player-container" aria-hidden="true"
         style="position:fixed;bottom:-9999px;left:-9999px;width:1px;height:1px;overflow:hidden;">
        <div id="yt-player"></div>
    </div>

    <!-- Visible Audio Control Widget -->
    <div class="audio-player" role="region" aria-label="Reproductor de música ambiental">
        <button class="audio-btn" id="audioPlayBtn"
                aria-label="Reproduir música de fons" title="Reproduir / Pausar">
            <span id="audioPlayIcon" aria-hidden="true">▶</span>
        </button>
        <div style="display:flex;flex-direction:column;gap:1px;max-width:140px;">
            <span class="audio-label" aria-hidden="true">Elden Ring OST</span>
            <span style="font-size:0.6rem;color:var(--gold-dim);font-family:'Cinzel',serif;letter-spacing:0.05em;">Lands Between Ambience</span>
        </div>
        <div style="display:flex;align-items:center;gap:0.4rem;">
            <span aria-hidden="true" style="font-size:0.65rem;color:var(--text-muted);">🔈</span>
            <input type="range" class="volume-slider" id="volSlider"
                   min="0" max="100" step="5" value="25"
                   aria-label="Volum de la música" />
            <span aria-hidden="true" style="font-size:0.65rem;color:var(--text-muted);">🔊</span>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://www.youtube.com/iframe_api"></script>
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
