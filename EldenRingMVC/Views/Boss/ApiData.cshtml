@model List<EldenRingMVC.Models.ApiBoss>
@{
    ViewData["Title"] = "API Live — Bosses";
    var apiStatus = ViewBag.ApiStatus as string ?? "unknown";
    var apiUrl = ViewBag.ApiUrl as string ?? "https://eldenring.fanapis.com/api/bosses";
    var isOk = apiStatus == "ok";
}

<div class="container section-elden">
    <div class="section-header">
        <p class="ornament" aria-hidden="true">⊕</p>
        <h1>Dades API en Viu</h1>
        <p class="text-muted-elden" style="font-style:italic; margin-top:0.5rem;">
            Dades obtingudes de l'API pública
            <a href="https://eldenring.fanapis.com" target="_blank" rel="noopener noreferrer"
               style="color:var(--gold-dim);">eldenring.fanapis.com</a>
            i deserialitzades amb <strong style="color:var(--gold)">Newtonsoft.Json</strong>
        </p>
    </div>

    <!-- Endpoint info -->
    <div class="quote-block mb-4" style="font-style:normal;">
        <span style="font-family:'Cinzel',serif; font-size:0.72rem; color:var(--gold); letter-spacing:0.1em;">ENDPOINT:</span>
        <br/>
        <code style="font-size:0.82rem; color:var(--text-muted);">GET @apiUrl</code>
    </div>

    <!-- Code snippet -->
    <div class="quote-block mb-4" style="font-family:monospace; font-size:0.82rem; font-style:normal; color:var(--text-main);">
        <span style="color:var(--gold); font-family:'Cinzel',serif; font-size:0.72rem; letter-spacing:0.1em;">SERIALITZACIÓ AMB NEWTONSOFT.JSON:</span><br/><br/>
        <span style="color:#7090a0;">// Crida a l'API externa</span><br/>
        <span style="color:var(--text-muted);">var json = await client.GetStringAsync(<span style="color:#a0c070;">"https://eldenring.fanapis.com/api/bosses?limit=20"</span>);</span><br/>
        <span style="color:var(--text-muted);">var result = JsonConvert.DeserializeObject&lt;<span style="color:#c0a060;">ApiBossResponse</span>&gt;(json);</span><br/>
        <span style="color:var(--text-muted);">var bosses = result?.Data ?? new List&lt;<span style="color:#c0a060;">ApiBoss</span>&gt;();</span>
    </div>

    <!-- API Status -->
    <div class="text-center mb-4" role="status" aria-live="polite">
        @if (isOk)
        {
            <span style="font-family:'Cinzel',serif; font-size:0.72rem; letter-spacing:0.1em; padding:0.3rem 0.8rem; background:rgba(20,80,20,0.3); color:#80c080; border:1px solid #204020; border-radius:2px;">
                ● API connectada · @Model.Count bosses carregats
            </span>
        }
        else
        {
            <span style="font-family:'Cinzel',serif; font-size:0.72rem; letter-spacing:0.1em; padding:0.3rem 0.8rem; background:rgba(139,32,32,0.3); color:#c07070; border:1px solid #5a2020; border-radius:2px;">
                ✗ Error de connexió — @apiStatus
            </span>
        }
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">
            <table class="table-elden" aria-label="Bosses obtinguts de l'API externa d'Elden Ring">
                <thead>
                    <tr>
                        <th scope="col">Imatge</th>
                        <th scope="col">Nom</th>
                        <th scope="col">Ubicació</th>
                        <th scope="col">Drops principals</th>
                        <th scope="col">Descripció</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var boss in Model)
                    {
                        <tr>
                            <td style="width:60px;">
                                @if (!string.IsNullOrEmpty(boss.Image))
                                {
                                    <img src="@boss.Image" alt="@boss.Name"
                                         style="width:52px; height:52px; object-fit:cover; border-radius:3px; border:1px solid var(--dark-border);"
                                         loading="lazy"
                                         onerror="this.style.display='none'" />
                                }
                            </td>
                            <td style="font-family:'Cinzel',serif; color:var(--gold); font-size:0.85rem; font-weight:600;">
                                @boss.Name
                            </td>
                            <td style="color:var(--text-muted); font-size:0.82rem;">
                                @(string.IsNullOrEmpty(boss.Location) ? "—" : boss.Location)
                            </td>
                            <td style="font-size:0.78rem; color:var(--text-muted);">
                                @(boss.Drops.Any() ? string.Join(", ", boss.Drops.Take(2)) : "—")
                            </td>
                            <td style="font-size:0.82rem; max-width:300px;">
                                @if (!string.IsNullOrEmpty(boss.Description))
                                {
                                    @(boss.Description.Length > 100 ? boss.Description.Substring(0, 100) + "…" : boss.Description)
                                }
                                else
                                {
                                    <span style="color:var(--text-muted);">—</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="quote-block text-center" role="alert">
            <p>No s'han pogut carregar dades de l'API. Comprova la connexió a internet del servidor.</p>
            <p style="font-size:0.85rem; color:var(--text-muted);">Error: @apiStatus</p>
        </div>
    }

    <div class="text-center mt-5">
        <a asp-action="Index" class="btn-elden">← Tornar als Bosses</a>
    </div>
</div>
